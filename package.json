{
  "name": "techradar",
  "private": true,
  "version": "1.4.0",
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "build": "prisma generate && nuxt build",
    "dev": "nuxt dev --host",
    "preview": "prisma migrate deploy && nuxt preview",
    "postinstall": "nuxt prepare && (git rev-parse --git-dir >/dev/null 2>&1 && git config core.hooksPath .githooks || true)",
    "lint": "eslint .",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nuxt/icon": "^2.2.3",
    "@prisma/client": "^6",
    "@tanstack/vue-query": "^5",
    "@vee-validate/zod": "^4",
    "@vueuse/core": "^13.9.0",
    "motion-v": "^2.3.0",
    "nuxt-auth-utils": "^0.5.29",
    "reka-ui": "^2.9.10",
    "shadcn-vue": "^2.7.4",
    "tw-animate-css": "^1.4.0",
    "vee-validate": "^4",
    "zod": "^3"
  },
  "devDependencies": {
    "@iconify-json/ph": "^1.2.2",
    "@nuxt/eslint": "^1",
    "@tailwindcss/vite": "^4.3.1",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "nuxt": "^4",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "prisma": "^6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vue-tsc": "^2"
  },
  "volta": {
    "node": "24.17.0"
  }
